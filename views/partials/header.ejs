<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' – ' : '' %>Reifendatenbank</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-speedometer2 me-2 fs-4"></i>
                <span class="fw-bold">Reifendatenbank</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link<%= currentPath === '/' ? ' active' : '' %>" href="/">
                            <i class="bi bi-house-door me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle<%= currentPath.startsWith('/reifendruck') ? ' active' : '' %>"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-clipboard-data me-1"></i>Reifendruck
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/reifendruck">
                                <i class="bi bi-list-ul me-2"></i>Alle Einträge</a></li>
                            <li><a class="dropdown-item" href="/reifendruck/neu">
                                <i class="bi bi-plus-circle me-2"></i>Neuer Eintrag</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle<%= currentPath.startsWith('/laufzeiten') ? ' active' : '' %>"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-graph-up me-1"></i>Laufzeiten
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/laufzeiten/reifen">
                                <i class="bi bi-circle me-2"></i>Reifen</a></li>
                            <li><a class="dropdown-item" href="/laufzeiten/felgen">
                                <i class="bi bi-gear me-2"></i>Felgen</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="d-flex">
                    <a class="btn btn-outline-success btn-sm me-2" href="/reifendruck/neu">
                        <i class="bi bi-plus-lg me-1"></i>Neuer Eintrag
                    </a>
                    <a class="btn btn-outline-light btn-sm" href="/export/csv">
                        <i class="bi bi-download me-1"></i>CSV Export
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-3">
        <% if (flash && flash.length > 0) { %>
            <% for (const msg of flash) { %>
                <div class="alert alert-<%= msg.category %> alert-dismissible fade show" role="alert">
                    <% if (msg.category === 'success') { %><i class="bi bi-check-circle me-2"></i>
                    <% } else if (msg.category === 'danger') { %><i class="bi bi-exclamation-triangle me-2"></i>
                    <% } else if (msg.category === 'warning') { %><i class="bi bi-exclamation-circle me-2"></i>
                    <% } else { %><i class="bi bi-info-circle me-2"></i><% } %>
                    <%= msg.message %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
        <% } %>
    </div>

    <main class="container-fluid py-3">
