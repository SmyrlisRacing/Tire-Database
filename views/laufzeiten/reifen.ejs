<% var pageTitle = 'Laufzeiten Reifen'; %>
<%- include('../partials/header') %>

<div class="row mb-4">
    <div class="col">
        <h1 class="display-6 fw-bold">
            <i class="bi bi-circle me-2 text-info"></i>Laufzeiten – Reifensätze
        </h1>
        <p class="text-muted mb-0">Kumulierte Laufleistung pro Reifensatz</p>
    </div>
</div>

<%
// Gruppiere Reifen nach Veranstaltung
const grouped = {};
for (const r of reifen) {
    const ev = r.veranstaltung || 'Ohne Event';
    if (!grouped[ev]) grouped[ev] = [];
    grouped[ev].push(r);
}
const eventNames = Object.keys(grouped);
%>
<% if (reifen.length > 0) { %>
<% for (const evName of eventNames) { %>
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-trophy me-2"></i><%= evName %></h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Set Nr.</th>
                    <th>Marke</th>
                    <th>Typ</th>
                    <th>Fahrer</th>
                    <th class="text-end">Runden</th>
                    <th class="text-end">Laufzeit (km)</th>
                    <th class="text-end">Einsätze</th>
                </tr>
            </thead>
            <tbody>
                <% for (const r of grouped[evName]) { %>
                <tr>
                    <td><span class="badge bg-primary fs-6"><%= r.set_nr %></span></td>
                    <td><%= r.marke || '–' %></td>
                    <td>
                        <% if (r.reifen_typ === 'Slicks') { %>
                        <span class="badge bg-dark"><i class="bi bi-sun me-1"></i>Slicks</span>
                        <% } else if (r.reifen_typ === 'Nass') { %>
                        <span class="badge bg-primary"><i class="bi bi-cloud-rain me-1"></i>Nass</span>
                        <% } else { %>–<% } %>
                    </td>
                    <td><%= r.fahrer || '–' %></td>
                    <td class="text-end"><%= r.gesamt_runden || 0 %></td>
                    <td class="text-end fw-bold fs-5"><%= r.gesamt_km || 0 %> km</td>
                    <td class="text-end"><span class="badge bg-info"><%= r.einsaetze || 0 %></span></td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
<% } else { %>
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="bi bi-circle display-1 text-muted"></i>
        <h3 class="mt-3 text-muted">Noch keine Reifensätze erfasst</h3>
        <p class="text-muted">Reifensätze werden automatisch erfasst, sobald eine Set-Nr. eingetragen wird.</p>
        <a href="/reifendruck/neu" class="btn btn-primary btn-lg mt-2">
            <i class="bi bi-plus-circle me-2"></i>Reifendruck-Eintrag anlegen
        </a>
    </div>
</div>
<% } %>

<%- include('../partials/footer') %>
